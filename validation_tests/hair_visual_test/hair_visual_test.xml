<?xml version='1.0' encoding='utf-8'?>
<!--
  Hair Visual Test Scene — renders wWavy.hair with white hair under a
  directional environment map to visually demonstrate the R / TT / TRT
  scattering lobes of the Chiang 2016 BCSDF.

  Camera: side-on view, looking from +X toward the strand cluster.
  Strand centroid: (-14.71, -0.42, 4.78).  Strands run along Z.
  A sun from +X at 20° elevation (see make_directional_envmap.py) will:
    - Show the R (specular) highlight as a bright streak along the strand
    - Show TT (forward scatter) as a bright halo on the back side
    - Show TRT (internal reflection) as a secondary highlight

  Environment map: textures/white_furnace.hdr  (a custom directional HDR
  generated by make_directional_envmap.py; named white_furnace.hdr because
  the renderer's envmap path is hardcoded to that filename, resolved
  relative to this file's directory).

  To run:
    python validation_tests/hair_visual_test/make_directional_envmap.py
    cd validation_tests/hair_visual_test
    <path>/nori-dxr.exe hair_visual_test.xml
-->
<scene>
    <integrator type="path_mis"/>

    <!--
      Camera looks from +X side across the strand cluster.
      Origin: x = centroid_x + 150 (pull back 150 units in +X)
              y = centroid_y + 20  (slight upward angle)
              z = centroid_z       (centered on strand Z midpoint)
      Target: strand centroid (-14.71, -0.42, 4.78)
      Up: Y axis
    -->
    <camera type="perspective">
        <float name="fov" value="60"/>
        <transform name="toWorld">
            <lookat target="-14.714, -0.419,  4.775"
                    origin=" 235.286,  -0.419,  4.775"
                    up="0, -1, 0"/>
        </transform>
        <integer name="height" value="480"/>
        <integer name="width"  value="640"/>
    </camera>

    <sampler type="independent">
        <integer name="sampleCount" value="512"/>
    </sampler>

    <!--
      White hair: color=(1,1,1) gives sigma_a ≈ 0, so all lobe energy
      comes back as scattered white light.  The directional env makes
      the per-lobe highlights visible:
        R   — sharp specular streak shifted by -2*alpha
        TT  — soft bright lobe on the transmission (far) side
        TRT — secondary glint, broader than R, shifted by +4*alpha
    -->
    <mesh type="hair">
        <string name="filename" value="../meshes/wWavy.hair"/>
        <integer name="sides" value="6"/>
        <float name="radiusScale" value="1.0"/>
        <bsdf type="hair_bsdf">
            <color name="color" value="1.0 1.0 1.0"/>
            <float name="beta_m" value="0.2"/>
            <float name="beta_n" value="0.3"/>
            <float name="alpha" value="2.0"/>
            <float name="eta" value="1.55"/>
        </bsdf>
    </mesh>
</scene>
