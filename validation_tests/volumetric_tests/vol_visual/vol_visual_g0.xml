<?xml version='1.0' encoding='utf-8'?>
<!-- Phase ablation: g=0 (isotropic scattering) -->
<scene>
    <string name="envmap" value="textures/sunset.hdr"/>
    <float name="envmapScale" value="1.0"/>
    <float name="evCompensation" value="0.0"/>
    <integrator type="path_mis"/>
    <camera type="perspective">
        <float name="fov" value="45"/>
        <transform name="toWorld">
            <lookat origin="0, 0, 15" target="0, 0, 0" up="0, 1, 0"/>
        </transform>
        <integer name="width"  value="256"/>
        <integer name="height" value="256"/>
    </camera>
    <sampler type="independent">
        <integer name="sampleCount" value="512"/>
    </sampler>
    <mesh type="obj">
        <string name="filename" value="sphere.obj"/>
        <bsdf type="diffuse">
            <color name="albedo" value="0.5 0.5 0.5"/>
        </bsdf>
    </mesh>
    <medium type="homogeneous">
        <float name="sigmaA" value="0.1"/>
        <float name="sigmaS" value="0.4"/>
        <float name="g"      value="0.0"/>
        <point name="boundsMin" value="-11, -11, -11"/>
        <point name="boundsMax" value=" 11,  11,  11"/>
    </medium>
</scene>
