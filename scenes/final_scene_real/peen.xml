<?xml version='1.0' encoding='utf-8'?>
<scene>
	<integrator type="path_mis"/>

	<camera type="perspective">
		<float name="fov" value="45"/>
		<transform name="toWorld">
			<lookat target="0.07, 3.87, 0.17"
			        origin="-5.0, 3.87, 0.17"
			        up="0, 1, 0"/>
		</transform>
		<integer name="width" value="1600"/>
		<integer name="height" value="1000"/>
	</camera>

	<sampler type="independent">
		<integer name="sampleCount" value="2048"/>
	</sampler>

	<!-- Dummy mesh so DXR has geometry for the acceleration structure -->
	<mesh type="obj">
		<string name="filename" value="meshes/dummy.obj"/>
		<bsdf type="diffuse">
			<color name="albedo" value="0 0 0"/>
		</bsdf>
	</mesh>

	<!-- Glass box enclosing the cloud volume -->
	<mesh type="obj">
		<string name="filename" value="meshes/peen_box.obj"/>
		<bsdf type="dielectric">
			<float name="intIOR" value="1.5"/>
			<float name="extIOR" value="1.0"/>
		</bsdf>
	</mesh>

	<!-- Area light: above and to the right of the volume -->
	<mesh type="obj">
		<string name="filename" value="meshes/peen_light.obj"/>
		<emitter type="area">
			<color name="radiance" value="40, 40, 38"/>
		</emitter>
		<bsdf type="diffuse">
			<color name="albedo" value="0 0 0"/>
		</bsdf>
	</mesh>

	<medium type="heterogeneous">
			<float name="sigmaA" value="0.005"/>
		<float name="sigmaS" value="4.0"/>
		<float name="g" value="0.7"/>
		<string name="volume" value="peen/volumes/peen.vol"/>
    <point name="boundsMin" value="-0.4744, 3.1193, -0.9344"/>
    <point name="boundsMax" value="0.5175, 4.6574, 1.2506"/>
	</medium>
</scene>